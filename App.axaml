<Application
    x:Class="AuthAvalonia.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AuthAvalonia"
    RequestedThemeVariant="Default">
    <!--  "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options.  -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="TextBlock.h1">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Margin" Value="5" />
        </Style>

        <Style Selector="TextBlock.accTitle">
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style Selector="TextBlock.totpCode">
            <Setter Property="FontSize" Value="28" />
        </Style>

        <Style Selector="Grid.accItem">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight3}" />
        </Style>
    </Application.Styles>
</Application>
